# --- Variables de entorno del Trofeo de Santiago ---

# Base de datos.
#  - Desarrollo (SQLite local):
DATABASE_URL="file:./dev.db"
#  - Para migrar a PostgreSQL en el futuro, cambia el `provider` en
#    prisma/schema.prisma a "postgresql" y usa una URL como:
#    DATABASE_URL="postgresql://usuario:password@host:5432/trofeo?schema=public"

# Secreto para firmar los tokens JWT del panel de administración.
# ¡Genera uno propio y mantenlo en secreto en producción!
JWT_SECRET="cambia-este-secreto-en-produccion"

# URL pública del sitio (usada por robots.txt y sitemap.xml).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
