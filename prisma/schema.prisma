// Esquema Prisma — Trofeo de Santiago
// Base de datos SQLite. Arquitectura preparada para migrar a PostgreSQL
// (basta cambiar `provider` y `DATABASE_URL`; no se usan tipos exclusivos de SQLite).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id          Int      @id @default(autoincrement())
  date        String // fecha de inicio (YYYY-MM-DD)
  endDate     String? // fecha de fin, opcional (para competiciones de varios días)
  time        String? // opcional
  name        String
  location    String? // opcional
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Team {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  totalPoints    Int              @default(0) // Calculado automáticamente (ver lib/standings.js)
  manualAdjust   Int              @default(0) // Ajuste manual del administrador
  observations   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  crossResults   CrossResult[]
  volleyMatchA   VolleyMatch[]    @relation("TeamA")
  volleyMatchB   VolleyMatch[]    @relation("TeamB")
  crossfitResult CrossfitResult?
  paellaResult   PaellaResult?
  psPlayers      PsPlayer[]
}

model CrossResult {
  id             Int      @id @default(autoincrement())
  teamId         Int
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  individualName String?
  time           String?
  points         Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model VolleyMatch {
  id            Int      @id @default(autoincrement())
  round         Int      @default(1) // Ronda del cuadro (1 = primera, mayor = final)
  roundLabel    String? // Nombre de la ronda escrito a mano (p. ej. "Cuartos", "Final")
  slot          Int      @default(0) // Posición dentro de la ronda
  teamAId       Int?
  teamA         Team?    @relation("TeamA", fields: [teamAId], references: [id])
  teamBId       Int?
  teamB         Team?    @relation("TeamB", fields: [teamBId], references: [id])
  teamAName     String? // Nombre escrito a mano (los equipos pueden no estar en la clasificación)
  teamBName     String?
  result        String? // p. ej. "2-1"
  teamAPoints   Int      @default(0)
  teamBPoints   Int      @default(0)
  status        String   @default("Pendiente") // Pendiente | EnJuego | Finalizado
  scheduledDate String?
  scheduledTime String?
  field         String?
  winnerId      Int?
  winnerName    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VolleyGroupTeam {
  id         Int      @id @default(autoincrement())
  groupName  String // p. ej. "Grupo 1"
  teamName   String
  played     Int      @default(0)
  wins       Int      @default(0)
  draws      Int      @default(0)
  losses     Int      @default(0)
  points     Int      @default(0)
  classified Boolean  @default(false) // Marcado a mano por el admin al acabar la fase
  createdAt  DateTime @default(now())
}

model PsGroupTeam {
  id         Int      @id @default(autoincrement())
  groupName  String
  teamName   String
  played     Int      @default(0)
  wins       Int      @default(0)
  draws      Int      @default(0)
  losses     Int      @default(0)
  points     Int      @default(0)
  classified Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model CrossfitResult {
  id        Int      @id @default(autoincrement())
  teamId    Int      @unique
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  time      String?
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaellaResult {
  id           Int      @id @default(autoincrement())
  teamId       Int      @unique
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sabor        Int      @default(0)
  puntoArroz   Int      @default(0)
  presentacion Int      @default(0)
  color        Int      @default(0)
  totalPoints  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// --- Torneo PlayStation EA SPORTS FC ---

model PsPlayer {
  id        Int       @id @default(autoincrement())
  name      String
  teamId    Int?
  team      Team?     @relation(fields: [teamId], references: [id])
  militaryUnit String? // Texto libre por si no está ligado a un equipo
  wins      Int       @default(0)
  losses    Int       @default(0)
  points    Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  matchesA  PsMatch[] @relation("PsPlayerA")
  matchesB  PsMatch[] @relation("PsPlayerB")
}

model PsMatch {
  id            Int       @id @default(autoincrement())
  round         Int       @default(1)
  roundLabel    String? // Nombre de la ronda escrito a mano
  slot          Int       @default(0)
  playerAId     Int?
  playerA       PsPlayer? @relation("PsPlayerA", fields: [playerAId], references: [id])
  playerBId     Int?
  playerB       PsPlayer? @relation("PsPlayerB", fields: [playerBId], references: [id])
  playerAName   String? // Nombre escrito a mano (participantes/equipos libres)
  playerBName   String?
  scoreA        Int?
  scoreB        Int?
  status        String    @default("Pendiente") // Pendiente | EnJuego | Finalizado
  scheduledTime String?
  field         String? // Lugar del enfrentamiento
  winnerId      Int?
  winnerName    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- Medios gestionados desde el admin (cartel, cabeceras, PDFs de normas) ---

model MediaAsset {
  key       String   @id // p. ej. cartel, header-cross, norma-cross
  path      String
  type      String   @default("image") // image | pdf
  label     String?
  updatedAt DateTime @updatedAt
}

// Configuración clave/valor genérica
model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
